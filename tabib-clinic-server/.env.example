# Tabib Clinic Server Configuration

# Database
DATABASE_URL=sqlite:///./clinic.db

# FastAPI
DEBUG=true
SECRET_KEY=change-me-in-production

# Clinic Information
CLINIC_NAME=Your Clinic Name
CLINIC_CITY=Your City
CLINIC_LAT=24.7136
CLINIC_LON=46.6753
CLINIC_PHONE=+966501234567
PUBLIC_IP=192.168.1.100

# Ollama Configuration
OLLAMA_URL=http://localhost:11434
MODEL_NAME=gemma4:26b
GEMMA_WORKERS=2

# Queue Settings
MAX_QUEUE_SIZE=50
REQUEST_TIMEOUT_SECONDS=300

# Dashboard Settings
# Generated randomly during setup - no default
DASHBOARD_PIN=

# Registry (Central Clinic Discovery)
REGISTRY_URL=https://registry.example.com
CLINIC_PRIVATE_KEY=optional-for-registry-auth

# Rate Limiting
RATE_LIMIT_CHAT=20
RATE_LIMIT_AUTH=5
